{
  "name": "keclima",
  "version": "0.8.11",
  "description": "KeClima – Progressive Web App de meteorologia completa",
  "homepage": "https://keclima.onrender.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/kcristtiannlp/keclima.git"
  },
  "type": "module",
  "private": true,
  "scripts": {
    "start": "python3 serve.py 8080",
    "serve": "python3 serve.py 8080",
    "serve:static": "python3 -m http.server 8080",
    "test": "bash scripts/smoke_test.sh",
    "smoke": "bash scripts/smoke_test.sh",
    "lint": "eslint src --ext .js",
    "format": "prettier --write \"src/**/*.{js,css,html}\" \"*.{js,json,html,md}\" \"public/**/*\""
  },
  "keywords": [
    "weather",
    "pwa",
    "meteorology",
    "open-meteo"
  ],
  "author": "KeClima",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  }
}
